# Backend only. Never put this key in the Expo/mobile app.
OPENAI_API_KEY=

# Cheap-first defaults for item identification.
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_VISION_DETAIL=low
OPENAI_VISION_MAX_TOKENS=400
OPENAI_IMAGE_MAX_EDGE=768
OPENAI_IMAGE_QUALITY=80
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=1
LOG_LEVEL=INFO
